# Resend (emails transaccionales)
RESEND_API_KEY=tu_api_key_de_resend
EMAIL_FROM=EnarmDuo <noreply@enarmduo.com>

# OpenPay (sandbox)
OPENPAY_MERCHANT_ID=tu_merchant_id
OPENPAY_PRIVATE_KEY=tu_llave_privada
OPENPAY_PUBLIC_KEY=tu_llave_publica
OPENPAY_SANDBOX=true

# URL del sitio (para redirects de OpenPay)
SITE_URL=https://enarmduo.com

# Backend API
BACKEND_API_URL=https://api.enarmduo.com/api

# Admin del backend (para crear cupones desde webhook)
ADMIN_USER=tu_usuario_admin
ADMIN_PASSWORD=tu_password_admin
