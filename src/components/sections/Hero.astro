---

---

<section class="w-full min-h-screen flex items-center justify-center relative overflow-hidden" style="background-color: var(--color-blanco); margin-top: -1px;">
	<!-- Partículas Flotantes (Fondo) -->
	<div class="absolute inset-0 z-0" id="contenedor-particulas">
		<svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
			<!-- Partículas visibles en desktop -->
			{Array.from({ length: 35 }).map((_, i) => (
				<circle
					class={`particula ${i >= 25 ? 'hidden md:block' : ''}`}
					cx={Math.random() * 100 + '%'}
					cy={Math.random() * 100 + '%'}
					r={Math.random() * 3 + 2}
					style={`fill: var(--color-particula); opacity: ${Math.random() * 0.4 + 0.25};`}
				/>
			))}
		</svg>
	</div>

	<!-- Contenido Principal (Primer plano) -->
	<div class="w-full px-6 md:px-8 flex justify-center relative z-10">
		<div class="max-w-3xl text-center">
			<h1 class="text-2xl md:text-4xl font-bold mb-6 px-4" style="color: var(--color-azul); font-family: 'Inter', sans-serif;">EnarmDuo App</h1>
			<p class="text-6xl md:text-6xl mb-1 font-bold px-4" style="color: var(--color-azul); font-family: 'Google Sans Flex', sans-serif;">
				Plataforma Educativa
			</p>
			<p class="text-4xl md:text-4xl mb-12 px-4" style="color: #4a5565; font-family: 'Google Sans Flex', sans-serif;">
				que te prepara para presentar el ENARM
			</p>
			<p class="text-lg md:text-xl mb-6 px-4" style="color: var(--color-azul); font-family: 'Inter', sans-serif; font-weight: 600;">
				Descarga la app
			</p>
			<div class="flex items-center justify-center gap-4 flex-wrap">
				<a href="/contacto" class="inline-block transition-all hover:opacity-80 hover:-translate-y-1">
					<img src="/img/badges/google-play-badge.svg" alt="Disponible en Google Play" class="h-14 md:h-16" />
				</a>
				<a href="/contacto" class="inline-block transition-all hover:opacity-80 hover:-translate-y-1">
					<img src="/img/badges/app-store-badge.svg" alt="Disponible en App Store" class="h-14 md:h-16" />
				</a>
			</div>
		</div>
	</div>
</section>

<script>
	// @ts-ignore
	import gsap from 'gsap';

	// Animar partículas flotantes
	const particulas = document.querySelectorAll('.particula');
	
	particulas.forEach((particula, index) => {
		// Movimiento aleatorio para cada partícula
		gsap.to(particula, {
			x: `random(-100, 100)`,
			y: `random(-100, 100)`,
			duration: `random(4, 8)`,
			repeat: -1,
			yoyo: true,
			ease: 'sine.inOut',
			delay: index * 0.1, // Escalonar inicio de animaciones
		});

		// Pulso de opacidad sutil
		gsap.to(particula, {
			opacity: `random(0.8, 1.1)`,
			duration: `random(3, 7)`,
			repeat: -1,
			yoyo: true,
			ease: 'sine.inOut',
		});
	});
</script>
