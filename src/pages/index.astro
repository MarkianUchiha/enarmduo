---
import Layout from '../layouts/Layout.astro';
import Header from '../components/core/Header.astro';
import Hero from '../components/sections/Hero.astro';
import Cintillo from '../components/sections/Cintillo.astro';
import Video from '../components/sections/Video.astro';
import Parallax from '../components/sections/Parallax.astro';
import BlogPreview from '../components/sections/BlogPreview.astro';
import Team from '../components/sections/Team.astro';
import Footer from '../components/core/Footer.astro';
---

<Layout
	title="EnarmDuo - Plataforma de estudio para el ENARM"
	description="Prepárate para el ENARM con casos clínicos interactivos, exámenes personalizados por especialidad, flashcards y estadísticas de progreso. Más de 10,000 reactivos."
>
	<Header />
	<Hero />
	<Cintillo />
	<Video />
	<Parallax />
	<BlogPreview />
	<Team />
	<Footer />
</Layout>
