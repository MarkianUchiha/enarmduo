---
import Layout from '../layouts/Layout.astro';
import Header from '../components/core/Header.astro';
import Footer from '../components/core/Footer.astro';

// Precios web con ~10% descuento vs app
const planes = [
	{
		nombre: 'Mensual',
		precioApp: 259,
		precioWeb: 233,
		periodo: '/mes',
		duracion: '1 mes de acceso',
		popular: false,
		ahorro: null,
	},
	{
		nombre: 'Trimestral',
		precioApp: 699,
		precioWeb: 629,
		periodo: '/3 meses',
		duracion: '3 meses de acceso',
		popular: true,
		ahorro: 'Ahorra $70',
	},
	{
		nombre: 'Anual',
		precioApp: 2399,
		precioWeb: 2159,
		periodo: '/año',
		duracion: '12 meses de acceso',
		popular: false,
		ahorro: 'Ahorra $240',
	},
];
---

<Layout title="Precios - EnarmDuo" description="Planes y precios de EnarmDuo. Prepárate para el ENARM con casos clínicos, exámenes y más.">
	<Header />

	<main class="pt-24 pb-16" style="background-color: var(--color-blanco); min-height: 100vh;">
		<div class="max-w-5xl mx-auto px-6 md:px-8">
			<!-- Encabezado -->
			<div class="text-center mb-4">
				<h1 class="text-3xl md:text-5xl font-bold mb-4" style="color: var(--color-azul); font-family: 'Inter', sans-serif;">
					Planes y Precios
				</h1>
				<p class="text-base md:text-lg max-w-2xl mx-auto mb-2" style="color: var(--color-Zinc); font-family: 'Google Sans Flex', sans-serif;">
					Elige el plan que mejor se adapte a tu preparación para el ENARM. Todos los planes incluyen acceso completo a la plataforma.
				</p>
				<p class="text-sm font-semibold inline-block px-4 py-1.5 rounded-full" style="background-color: #e8f4f8; color: var(--color-azul);">
					Precios exclusivos en web — hasta 10% menos que en la app
				</p>
			</div>

			<!-- Grid de planes -->
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 mt-12">
				{planes.map((plan) => (
					<div class={`plan-card relative rounded-2xl p-8 transition-all duration-300 ${plan.popular ? 'plan-popular' : 'plan-regular'}`}>
						{plan.popular && (
							<span class="absolute -top-3 left-1/2 -translate-x-1/2 text-white text-xs font-bold px-4 py-1 rounded-full" style="background-color: var(--color-azul);">
								Más popular
							</span>
						)}

						<div class="text-center mb-6">
							<h3 class="text-xl font-bold mb-2" style="color: var(--color-azul); font-family: 'Inter', sans-serif;">
								{plan.nombre}
							</h3>
							<p class="text-sm" style="color: var(--color-Zinc);">
								{plan.duracion}
							</p>
						</div>

						<!-- Precio -->
						<div class="text-center mb-6">
							<div class="flex items-baseline justify-center gap-1">
								<span class="text-4xl md:text-5xl font-bold" style="color: var(--color-azul); font-family: 'Inter', sans-serif;">
									${plan.precioWeb.toLocaleString('es-MX')}
								</span>
								<span class="text-sm" style="color: var(--color-Zinc);">
									MXN
								</span>
							</div>
							<p class="text-xs mt-1 line-through" style="color: var(--color-gris);">
								${plan.precioApp.toLocaleString('es-MX')} MXN en la app
							</p>
							{plan.ahorro && (
								<span class="inline-block mt-2 text-xs font-semibold px-3 py-1 rounded-full" style="background-color: #d4edda; color: #155724;">
									{plan.ahorro}
								</span>
							)}
						</div>

						<!-- Beneficios -->
						<ul class="mb-8 space-y-3">
							<li class="flex items-center gap-2 text-sm" style="color: var(--color-azul);">
								<svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-azul);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Casos clínicos ilimitados
							</li>
							<li class="flex items-center gap-2 text-sm" style="color: var(--color-azul);">
								<svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-azul);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Exámenes personalizados
							</li>
							<li class="flex items-center gap-2 text-sm" style="color: var(--color-azul);">
								<svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-azul);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Estadísticas detalladas
							</li>
							<li class="flex items-center gap-2 text-sm" style="color: var(--color-azul);">
								<svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-azul);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Flashcards y guías
							</li>
							<li class="flex items-center gap-2 text-sm" style="color: var(--color-azul);">
								<svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-azul);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
								Sistema de ranking
							</li>
						</ul>

						<!-- Botón (por ahora redirige a contacto) -->
						<a
							href="/contacto"
							class={`block w-full text-center py-3 rounded-lg font-semibold transition-all duration-200 no-underline ${plan.popular ? 'plan-btn-popular' : 'plan-btn-regular'}`}
						>
							Elegir plan
						</a>
					</div>
				))}
			</div>

			<!-- Nota -->
			<div class="text-center mt-12">
				<p class="text-sm" style="color: var(--color-Zinc); font-family: 'Google Sans Flex', sans-serif;">
					Todos los precios incluyen IVA. Al completar tu compra recibirás un código de acceso para activar tu suscripción en la app.
				</p>
				<p class="text-xs mt-2" style="color: var(--color-gris);">
					¿Tienes un cupón? Actívalo directamente desde la app.
				</p>
			</div>
		</div>
	</main>

	<Footer />
</Layout>

<style>
	.plan-regular {
		border: 1px solid #e5e7eb;
		background: white;
	}

	.plan-regular:hover {
		border-color: var(--color-azul);
		box-shadow: 0 4px 20px rgba(2, 74, 112, 0.08);
		transform: translateY(-4px);
	}

	.plan-popular {
		border: 2px solid var(--color-azul);
		background: white;
		box-shadow: 0 4px 24px rgba(2, 74, 112, 0.12);
	}

	.plan-popular:hover {
		transform: translateY(-4px);
		box-shadow: 0 8px 32px rgba(2, 74, 112, 0.18);
	}

	.plan-btn-regular {
		background-color: transparent;
		border: 2px solid var(--color-azul);
		color: var(--color-azul);
	}

	.plan-btn-regular:hover {
		background-color: var(--color-azul);
		color: white;
	}

	.plan-btn-popular {
		background-color: var(--color-azul);
		color: white;
	}

	.plan-btn-popular:hover {
		opacity: 0.9;
	}
</style>
